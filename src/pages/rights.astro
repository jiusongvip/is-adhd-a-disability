 ---
 import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../data/site";
 const pageSchema = { "@context": "https://schema.org", "@type": "Article", "headline": "ADHD Disability Rights Checklist", "description": "A practical checklist of legal rights for individuals with ADHD across employment, education, public services, and housing.", "datePublished": "2026-07-22", "publisher": siteConfig.publisher, "mainEntityOfPage": { "@type": "WebPage", "@id": "https://isadhdadisability.com/rights" } };
 const rights = [
   { area: "Employment (ADA)", items: ["Right to reasonable accommodations", "Protection from discrimination", "Confidentiality of medical information", "Right to participate in the interactive process", "Right to file an EEOC complaint"] },
   { area: "Education K-12 (Section 504/IDEA)", items: ["Free appropriate public education (FAPE)", "Evaluation for disability at no cost to parents", "504 Plan or IEP with individualized accommodations", "Least restrictive environment placement", "Procedural safeguards for parents"] },
   { area: "Higher Education (ADA/Section 504)", items: ["Academic adjustments and auxiliary aids", "Access to campus facilities and programs", "Right to self-identify and request accommodations", "Testing accommodations (extended time, separate room)", "Note-taking and recording lecture permissions"] },
   { area: "Public Services (ADA Title II)", items: ["Equal access to government services and programs", "Reasonable modifications to policies and procedures", "Effective communication (auxiliary aids)", "Accessible public transportation"] },
   { area: "Housing (Fair Housing Act)", items: ["Reasonable accommodations in housing rules and policies", "Reasonable modifications to living space", "Protection from disability-based discrimination in renting and buying"] }
 ];
 ---
 <BaseLayout title="ADHD Disability Rights Checklist: ADA, 504, IDEA, Work" description="A practical checklist of legal rights for individuals with ADHD across employment, education, public services, and housing. Covers ADA, 504, and IDEA." canonicalURL="https://isadhdadisability.com/rights" ogImage="/images/rights.webp" schema={pageSchema}>
   <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12 md:pt-20 md:pb-16">
     <nav class="text-sm text-zinc-400 mb-6"><a href="/" class="hover:text-accent">Home</a> / Rights</nav>
     <div class="flex flex-col md:flex-row gap-8 items-start"><div class="max-w-3xl flex-1"><p class="text-sm font-medium text-accent mb-4">Your Rights</p><h1 class="text-3xl md:text-5xl font-bold text-zinc-900 leading-tight tracking-tight">ADHD Disability Rights Checklist: ADA, 504, IDEA, Work</h1><p class="mt-6 text-lg text-zinc-600 leading-relaxed max-w-2xl">A clear, practical overview of your legal rights under US disability laws. Know what protections apply to you, across employment, education, public services, and housing.</p></div><div class="hidden md:block w-80 flex-shrink-0"><img src="/images/rights.webp" alt="Legal documents and pen representing disability rights" class="rounded-xl shadow-lg w-full" width="320" height="213" loading="eager" /></div></div>
   </section>
   <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 md:pb-24"><div class="max-w-3xl space-y-12">
     {rights.map((r) => (<div><h2 class="text-xl font-semibold text-zinc-900 mb-4 border-b border-zinc-200 pb-2">{r.area}</h2><h3 class="text-sm font-medium text-accent mb-3">Your rights under federal law</h3><ul class="space-y-3">{r.items.map((item) => (<li class="flex items-start gap-3 text-sm text-zinc-600"><svg class="w-5 h-5 text-accent mt-0.5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg><span>{item}</span></li>))}</ul></div>))}
   </div></section>
   <section class="bg-zinc-50 border-y border-zinc-200"><div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16"><h2 class="text-xl font-semibold text-zinc-900 mb-4">What to do if your rights are violated</h2><h3 class="text-sm font-medium text-accent mb-3">Steps to take action</h3><div class="max-w-3xl prose"><ol><li><strong>Document the incident.</strong> Write down what happened, when, who was involved, and any witnesses.</li><li><strong>File an internal complaint</strong> with your employer, school, or service provider.</li><li><strong>File a complaint with the relevant agency</strong> (EEOC for employment, OCR for education, HUD for housing).</li><li><strong>Consult an attorney</strong> who specializes in disability law.</li></ol></div></div></section>
   <section class="border-t border-zinc-200"><div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8"><p class="text-xs text-zinc-400 leading-relaxed max-w-3xl"><strong class="text-zinc-500">Disclaimer:</strong> This checklist is a general overview and does not constitute legal advice. Rights vary by jurisdiction and individual circumstances.</p></div></section>
 </BaseLayout>
