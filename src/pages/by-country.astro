 <BaseLayout title="Is ADHD a Disability? by Country: US, UK, Canada and More" description="How ADHD disability status and legal protections vary across countries. Compare the US, UK, Canada, Australia, EU, and others. Find out your rights." canonicalURL="https://isadhdadisability.com/by-country" ogImage="/images/by-country.webp" schema={pageSchema}>
   <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12 md:pt-20 md:pb-16">
     <nav class="text-sm text-zinc-400 mb-6"><a href="/" class="hover:text-accent">Home</a> / By Country</nav>
     <div class="flex flex-col md:flex-row gap-8 items-start"><div class="max-w-3xl flex-1"><p class="text-sm font-medium text-accent mb-4">International Comparison</p><h1 class="text-3xl md:text-5xl font-bold text-zinc-900 leading-tight tracking-tight">Is ADHD a Disability in Your Country?</h1><p class="mt-6 text-lg text-zinc-600 leading-relaxed max-w-2xl">ADHD disability status varies by country. Here is how major English-speaking countries and the European Union classify ADHD under their disability laws.</p></div><div class="hidden md:block w-80 flex-shrink-0"><img src="/images/by-country.webp" alt="World map showing global comparison of ADHD disability laws" class="rounded-xl shadow-lg w-full" width="320" height="213" loading="eager" /></div></div>
   </section>
   <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 md:pb-24"><div class="space-y-8 max-w-3xl">
     {countries.map((c) => (<div class="border border-zinc-200 rounded-lg p-6"><h2 class="text-lg font-semibold text-zinc-900 mb-1">{c.name}</h2><h3 class="text-xs font-medium text-zinc-400 mb-3">{c.laws}</h3><p class="text-sm text-accent font-medium mb-2">{c.status}</p><p class="text-sm text-zinc-500 leading-relaxed">{c.notes}</p></div>))}
   </div></section>
   <section class="border-t border-zinc-200"><div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8"><p class="text-xs text-zinc-400 leading-relaxed max-w-3xl"><strong class="text-zinc-500">Disclaimer:</strong> This comparison is a general overview. Laws change and interpretations vary. Consult a local disability advocate or attorney for current guidance in your jurisdiction.</p></div></section>
 </BaseLayout>
