 import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../data/site";
 const pageSchema = { "@context": "https://schema.org", "@type": "Article", "headline": "Is ADHD a Disability by Country?", "description": "How ADHD disability status and legal protections vary across countries.", "datePublished": "2026-07-22", "publisher": siteConfig.publisher, "mainEntityOfPage": { "@type": "WebPage", "@id": "https://isadhdadisability.com/by-country" } };
 const countries = [
   { name: "United States", laws: "ADA, Section 504, IDEA, Fair Housing Act", status: "Yes -- ADHD is recognized as a disability under multiple federal laws when it substantially limits major life activities.", notes: "SSDI/SSI benefits possible but difficult. Workplace and education accommodations available. Most comprehensive protections globally." },
   { name: "United Kingdom", laws: "Equality Act 2010", status: "Yes -- ADHD can qualify as a disability if it has a substantial and long-term adverse effect on daily activities.", notes: "Employers must make reasonable adjustments. Access to Work scheme provides funding for workplace support. PIP (Personal Independence Payment) available." },
   { name: "Canada", laws: "Canadian Human Rights Act, Provincial Codes", status: "Yes -- ADHD is recognized as a disability under federal and provincial human rights legislation.", notes: "Duty to accommodate applies across employment, education, and services. CPP Disability benefits may be available in some cases." },
   { name: "Australia", laws: "Disability Discrimination Act 1992", status: "Yes -- ADHD is covered under disability discrimination law.", notes: "NDIS (National Disability Insurance Scheme) access possible with proper documentation. Workplace and education accommodations available." },
   { name: "European Union", laws: "EU Employment Equality Directive, UN CRPD", status: "Varies by country, but generally yes under EU directives.", notes: "Most EU countries recognize ADHD as a disability for employment nondiscrimination. Individual country implementations differ significantly." },
   { name: "Ireland", laws: "Employment Equality Acts, Equal Status Acts", status: "Yes -- ADHD is recognized as a disability under Irish equality legislation.", notes: "Reasonable accommodation requirement applies in employment and education." },
   { name: "New Zealand", laws: "Human Rights Act 1993, Health and Disability Commissioner Act", status: "Yes -- ADHD is covered under disability discrimination protections.", notes: "Reasonable accommodation obligations in employment and education." }
 ];
