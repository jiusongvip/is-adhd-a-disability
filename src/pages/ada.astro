     <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20"><div class="max-w-3xl">
       <div class="callout-accent p-6 rounded-xl mb-10 not-prose">
         <p class="font-bold text-zinc-900 text-base mb-3">Key takeaways</p>
